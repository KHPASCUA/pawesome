# E2E Testing Environment Variables
# Copy this file to .env.e2e and fill in values for live backend testing
# For mock mode (E2E_LIVE not set), these defaults are used from test-utils.js

# Live backend flag - set to 'true' to test against real API
E2E_LIVE=false

# ===========================================
# ROLE-BASED TEST ACCOUNT CREDENTIALS
# ===========================================
# These should match the seeded test accounts in backend/database/seeders/E2ESeeder.php
# Default passwords: password123

# Admin role - system management
E2E_ADMIN_EMAIL=admin@test.com
E2E_ADMIN_PASSWORD=password123

# Manager role - team oversight
E2E_MANAGER_EMAIL=manager@test.com
E2E_MANAGER_PASSWORD=password123

# Cashier role - POS and payments
E2E_CASHIER_EMAIL=cashier@test.com
E2E_CASHIER_PASSWORD=password123

# Customer role - client portal
E2E_CUSTOMER_EMAIL=customer@test.com
E2E_CUSTOMER_PASSWORD=password123

# Inventory role - stock management
E2E_INVENTORY_EMAIL=inventory@test.com
E2E_INVENTORY_PASSWORD=password123

# Payroll role - salary management
E2E_PAYROLL_EMAIL=payroll@test.com
E2E_PAYROLL_PASSWORD=password123

# Receptionist role - bookings/orders (main operator)
E2E_RECEPTIONIST_EMAIL=receptionist@test.com
E2E_RECEPTIONIST_PASSWORD=password123

# Veterinary role - medical services
E2E_VETERINARY_EMAIL=veterinary@test.com
E2E_VETERINARY_PASSWORD=password123

# ===========================================
# TEST CONFIGURATION
# ===========================================
E2E_BASE_URL=http://localhost:3000
E2E_API_URL=http://localhost:8000
