APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI Chatbot Configuration (Optional - enables AI-powered responses)
# Get your API key from: https://ai.google.dev (Google AI Studio)
CHATBOT_AI_ENABLED=false
CHATBOT_AI_API_KEY=
# Gemini models: gemini-1.5-flash (fast/cheap, 1500 req/day FREE), gemini-1.5-pro (powerful)
CHATBOT_AI_MODEL=gemini-1.5-flash
# Google Gemini API endpoint
CHATBOT_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Hybrid Mode: faq_first | ai_first | smart
CHATBOT_HYBRID_MODE=faq_first

# Telegram Bot Configuration
# Get bot token from @BotFather: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Webhook URL - must be publicly accessible HTTPS URL
# Local testing: Use ngrok to expose your local server
# Example: https://your-ngrok-url.ngrok.io/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=

# Webhook Secret Token (optional but recommended for security)
# Generate a random string: php -r "echo bin2hex(random_bytes(32));"
# This verifies webhook requests are from Telegram
TELEGRAM_WEBHOOK_SECRET=

# Admin Chat ID for admin notifications (optional)
# Get your chat ID by messaging the bot and checking webhook logs
TELEGRAM_ADMIN_CHAT_ID=

# Frontend URL for deep links (production)
FRONTEND_URL=https://your-frontend-domain.com
